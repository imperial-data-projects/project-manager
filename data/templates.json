{
  "lifecycles": {
    "application": {
      "label": "Application",
      "phases": [
        {
          "id": "interview",
          "label": "Stakeholder Interview",
          "stakeholderLabel": "Requirements Gathering",
          "order": 1,
          "description": "Sit down with primary stakeholder, fill out template interview. Define goals, users, workflows, pain points.",
          "effortRange": "1-3h",
          "waitType": "scheduling"
        },
        {
          "id": "workflow",
          "label": "Workflow Assignment",
          "stakeholderLabel": "Workflow Design",
          "order": 2,
          "description": "From interview output, define app screens, user workflows, data model. Internal planning step.",
          "effortRange": "2-4h",
          "waitType": null
        },
        {
          "id": "wireframe",
          "label": "Wireframe",
          "stakeholderLabel": "Layout Design",
          "order": 3,
          "description": "Create wireframe layouts for each screen. Low-fidelity, focused on structure and flow.",
          "effortRange": "2-6h",
          "waitType": null
        },
        {
          "id": "mockups",
          "label": "Mockups Sent",
          "stakeholderLabel": "Design Review",
          "order": 4,
          "description": "High-fidelity mockups sent to stakeholder for approval. Gate: requires stakeholder sign-off.",
          "effortRange": "1-2h",
          "waitType": "approval"
        },
        {
          "id": "backend",
          "label": "Backend Build",
          "stakeholderLabel": "Core Development",
          "order": 5,
          "description": "API endpoints, database schema, business logic, integrations. Heaviest development phase.",
          "effortRange": "8-40h",
          "waitType": null
        },
        {
          "id": "frontend",
          "label": "Frontend Build",
          "stakeholderLabel": "Interface Development",
          "order": 6,
          "description": "React UI implementation. Components, forms, data display, interactions.",
          "effortRange": "8-40h",
          "waitType": null
        },
        {
          "id": "dev-release",
          "label": "Dev Release",
          "stakeholderLabel": "Preview Release",
          "order": 7,
          "description": "Deploy to development environment. Stakeholder gets first hands-on access.",
          "effortRange": "1-3h",
          "waitType": null
        },
        {
          "id": "testing",
          "label": "Testing & Iteration",
          "stakeholderLabel": "Testing & Feedback",
          "order": 8,
          "description": "Stakeholder testing, bug reports, refinement cycles. Duration depends on feedback volume.",
          "effortRange": "4-20h",
          "waitType": "feedback"
        },
        {
          "id": "production",
          "label": "Production Release",
          "stakeholderLabel": "Go Live",
          "order": 9,
          "description": "Final deployment to production. Communication to users, monitoring.",
          "effortRange": "1-3h",
          "waitType": null
        }
      ]
    },
    "powerbi": {
      "label": "Power BI Dashboard",
      "phases": [
        {
          "id": "interview",
          "label": "Stakeholder Interview",
          "stakeholderLabel": "Requirements Gathering",
          "order": 1,
          "description": "Template interview with primary stakeholder. Define KPIs, data sources, audience.",
          "effortRange": "1-2h",
          "waitType": "scheduling"
        },
        {
          "id": "kpi-planning",
          "label": "Page & KPI Planning",
          "stakeholderLabel": "Dashboard Planning",
          "order": 2,
          "description": "Define number of pages, KPIs per page, data relationships. Submit to stakeholder for approval.",
          "effortRange": "2-4h",
          "waitType": "approval"
        },
        {
          "id": "mockup-review",
          "label": "Mockup Review",
          "stakeholderLabel": "Layout Review",
          "order": 3,
          "description": "Create and submit page layout mockups. Gate: requires stakeholder sign-off.",
          "effortRange": "2-4h",
          "waitType": "approval"
        },
        {
          "id": "build",
          "label": "Build",
          "stakeholderLabel": "Development",
          "order": 4,
          "description": "Build report pages in Power BI against approved layouts and KPI register.",
          "effortRange": "4-16h",
          "waitType": null
        },
        {
          "id": "release",
          "label": "Release",
          "stakeholderLabel": "Go Live",
          "order": 5,
          "description": "Publish to Power BI workspace, configure refresh schedule, share with stakeholders.",
          "effortRange": "1-2h",
          "waitType": null
        }
      ]
    },
    "auto-report": {
      "label": "Auto Generated Report",
      "phases": [
        {
          "id": "report-review",
          "label": "Report Review",
          "stakeholderLabel": "Requirements Gathering",
          "order": 1,
          "description": "Review existing manual report with stakeholder. Understand data sources, layout, recipients, frequency.",
          "effortRange": "1-2h",
          "waitType": "scheduling"
        },
        {
          "id": "report-build",
          "label": "Report Build",
          "stakeholderLabel": "Report Design",
          "order": 2,
          "description": "Recreate report using imperial-core Excel formatter. Match or improve on legacy layout.",
          "effortRange": "2-6h",
          "waitType": null
        },
        {
          "id": "report-approval",
          "label": "Report Approval",
          "stakeholderLabel": "Design Review",
          "order": 3,
          "description": "Send sample report to stakeholder for sign-off on format and data accuracy.",
          "effortRange": "1-2h",
          "waitType": "approval"
        },
        {
          "id": "notebook-build",
          "label": "Notebook Build",
          "stakeholderLabel": "Automation",
          "order": 4,
          "description": "Create Fabric notebook to query data, generate report, and email via Graph. Schedule monthly trigger.",
          "effortRange": "2-6h",
          "waitType": null
        },
        {
          "id": "testing",
          "label": "Testing",
          "stakeholderLabel": "Verification",
          "order": 5,
          "description": "Stakeholder verifies a live test run. Confirm data, formatting, delivery, and schedule.",
          "effortRange": "1-3h",
          "waitType": "feedback"
        },
        {
          "id": "production",
          "label": "Production Release",
          "stakeholderLabel": "Go Live",
          "order": 6,
          "description": "Enable production schedule. Confirm first automated delivery.",
          "effortRange": "0.5-1h",
          "waitType": null
        }
      ]
    },
    "vendsys": {
      "label": "Vendsys Transition",
      "workstreams": [
        {
          "id": "products",
          "label": "Products",
          "tasks": [
            { "id": "barcode-match", "label": "Barcode Match & Parity Report", "owner": "me" },
            { "id": "parity-decisions", "label": "Parity Decisions", "owner": "them" },
            { "id": "code-conversion", "label": "Code Conversion", "owner": "me" }
          ]
        },
        {
          "id": "accounts",
          "label": "Accounts",
          "tasks": [
            { "id": "address-validation", "label": "Address & Name Verification", "owner": "me" },
            { "id": "account-fixes", "label": "Account Fixes", "owner": "them" },
            { "id": "consolidation-review", "label": "Consolidation Review", "owner": "me" }
          ]
        },
        {
          "id": "assets",
          "label": "Assets",
          "tasks": [
            { "id": "app-deployed", "label": "Asset Validation App Deployed", "owner": "me" },
            { "id": "field-validation", "label": "Field Validation", "owner": "them" },
            { "id": "asset-list-verified", "label": "Asset List Verified", "owner": "me" }
          ]
        },
        {
          "id": "financial",
          "label": "Financial",
          "tasks": [
            { "id": "commission-audit", "label": "Commission Structure Audit", "owner": "me" },
            { "id": "commission-fixes", "label": "Commission Fixes", "owner": "them" },
            { "id": "subsidy-audit", "label": "Subsidy Structure Audit", "owner": "me" },
            { "id": "subsidy-fixes", "label": "Subsidy Fixes", "owner": "them" },
            { "id": "billing-verification", "label": "Billing & Rental Verification", "owner": "me" },
            { "id": "billing-fixes", "label": "Billing Fixes", "owner": "them" }
          ]
        },
        {
          "id": "onhand-monitoring",
          "label": "Onhand Monitoring",
          "recurring": true,
          "startsAfter": "products.parity-decisions",
          "tasks": []
        }
      ],
      "lockdown": [
        { "id": "initial-workbook", "label": "Initial Workbook", "offset": -30 },
        { "id": "account-lock", "label": "Account Lock", "offset": -21, "validation": "Accounts & assets imported, validate against source" },
        { "id": "onhand-final", "label": "Final Onhand Audit", "offset": -15 },
        { "id": "planogram-lock", "label": "Planogram Lock", "offset": -10, "validation": "Planograms imported, validate against source" },
        { "id": "go-live", "label": "Go-Live", "offset": 0 }
      ]
    }
  },
  "domains": {
    "operations": { "label": "Operations", "color": "ocean" },
    "customer-svc": { "label": "Customer Service", "color": "indigo" },
    "merchandising": { "label": "Merchandising", "color": "amethyst" },
    "logistics": { "label": "Logistics", "color": "rose" },
    "accounting": { "label": "Accounting", "color": "umber" },
    "executive": { "label": "Executive", "color": "slate" }
  }
}
